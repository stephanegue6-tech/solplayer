{
  "name": "crimtrack-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "CrimTrack — application desktop Windows (backend embarqué + interface web)",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dist:win": "electron-builder --win nsis"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0"
  },
  "build": {
    "appId": "org.crimtrack.desktop",
    "productName": "CrimTrack",
    "asar": true,
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      { "from": "resources/backend", "to": "backend" },
      { "from": "resources/frontend", "to": "frontend" }
    ],
    "win": {
      "target": ["nsis"]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
